{
  "entities": {
    "User": {
      "title": "User",
      "description": "Perfil do usuário/membro da comunidade",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID único do Firebase Auth" },
        "name": { "type": "string", "description": "Nome completo" },
        "email": { "type": "string", "description": "E-mail de contato" },
        "photoURL": { "type": "string", "description": "URL da foto de perfil" },
        "bannerURL": { "type": "string", "description": "URL da foto do banner do perfil" },
        "bio": { "type": "string", "description": "Breve biografia ou descrição da empresa" },
        "category": { "type": "string", "description": "Categoria do serviço prestado (Tecnologia, Design, Marketing, Consultoria, Cozinha, Limpeza, Manutenção, Beleza, Educação, Saúde, Eventos, Jurídico, Financeiro, Assistência, Reformas, Automotivo, Moda, Bem Estar, Pet Care, Fotografia, Música, Idiomas, Esportes, Festas, Transporte)" },
        "isProvider": { "type": "boolean", "description": "Se o usuário é um prestador de serviço" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "Papel do usuário no sistema" },
        "contacts": { "type": "array", "items": { "type": "string" }, "description": "Lista de UIDs de contatos salvos" },
        "whatsapp": { "type": "string", "description": "Número de contato WhatsApp" },
        "serviceType": { "type": "string", "description": "Tipo de serviço oferecido (ex: Manutenção de computadores)" },
        "phones": { "type": "array", "items": { "type": "string" }, "description": "Lista de telefones adicionais" },
        "location": { "type": "string", "description": "Cidade/Estado" },
        "ward": { "type": "string", "description": "Nome da Ala (SUD)" },
        "companyName": { "type": "string", "description": "Nome da Empresa" },
        "socialLinks": { 
          "type": "object", 
          "properties": {
            "instagram": { "type": "string" },
            "facebook": { "type": "string" },
            "linkedin": { "type": "string" },
            "website": { "type": "string" }
          }
        },
        "gallery": { "type": "array", "items": { "type": "string" }, "description": "URLs de fotos da galeria (máx 5)" },
        "rating": { "type": "number", "description": "Avaliação média" },
        "reviewCount": { "type": "number", "description": "Total de avaliações" },
        "experienceYears": { "type": "number", "description": "Anos de experiência" },
        "verifiedMember": { "type": "boolean", "description": "Se o membro foi verificado pela comunidade" },
        "isBlocked": { "type": "boolean", "description": "Se o usuário está bloqueado pelo administrador" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Data de criação do perfil" }
      },
      "required": ["uid", "name", "email", "isProvider"]
    },
    "Service": {
      "title": "Service",
      "description": "Detalhes do serviço oferecido",
      "type": "object",
      "properties": {
        "providerId": { "type": "string", "description": "UID do prestador" },
        "title": { "type": "string", "description": "Título do serviço" },
        "description": { "type": "string", "description": "Descrição detalhada" },
        "category": { "type": "string", "description": "Categoria" },
        "price": { "type": "string", "description": "Preço ou faixa de preço (opcional)" }
      },
      "required": ["providerId", "title", "description", "category"]
    },
    "Rating": {
      "title": "Rating",
      "description": "Avaliação de um serviço ou empresa (Anônima)",
      "type": "object",
      "properties": {
        "toId": { "type": "string", "description": "UID do prestador avaliado" },
        "score": { "type": "number", "description": "Nota de 1 a 5" },
        "comment": { "type": "string", "description": "Comentário opcional" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["toId", "score"]
    },
    "UserVote": {
      "title": "UserVote",
      "description": "Registro privado de voto para evitar duplicidade",
      "type": "object",
      "properties": {
        "providerId": { "type": "string" },
        "votedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["providerId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Coleção de perfis de usuários"
    },
    "/users/{userId}/private_data/votes/{providerId}": {
      "schema": "UserVote",
      "description": "Registro privado de votos do usuário"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Coleção de serviços oferecidos"
    },
    "/ratings/{ratingId}": {
      "schema": "Rating",
      "description": "Coleção de avaliações anônimas"
    }
  }
}
